:host {
  display: block;
  width: 100%;
  height: 100%;
  pointer-events: auto;
}

.cat-pet-stage {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 72px;
}

.cat-pet-debug-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.cat-debug-arena {
  position: absolute;
  inset: 0;
  border-left: 1rpx dashed rgba(74, 222, 128, 0.45);
  border-right: 1rpx dashed rgba(74, 222, 128, 0.45);
  border-top: 3rpx solid rgba(250, 204, 21, 0.9);
  border-bottom: 3rpx solid rgba(250, 204, 21, 0.9);
  border-radius: 12rpx;
  background: rgba(74, 222, 128, 0.05);
  box-sizing: border-box;
}

.cat-debug-roam {
  position: absolute;
  right: 0;
  top: 0;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  line-height: 1.4;
}

.cat-debug-roam-on {
  color: #052e16;
  background: rgba(74, 222, 128, 0.85);
}

.cat-debug-roam-off {
  color: #fecaca;
  background: rgba(239, 68, 68, 0.35);
}

.cat-pet-wrap {
  position: absolute;
  left: 0;
  top: 0;
  width: 72px;
  height: 72px;
  will-change: transform;
  z-index: 2;
}

.cat-hit-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 72px;
  height: 72px;
  z-index: 3;
}

.cat-sprite-clip {
  width: 72px;
  height: 72px;
  overflow: hidden;
  position: relative;
  z-index: 1;
  pointer-events: none;
}

.cat-sprite-sheet {
  display: block;
  position: absolute;
  left: 0;
  top: 0;
  pointer-events: none;
  image-rendering: pixelated;
  image-rendering: crisp-edges;
}
