.chart-wrap {
  width: 100%;
  height: 400rpx;
  padding: 48rpx 0 0;
}

.col-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 100%;
  gap: 8rpx;
}

.col-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  position: relative;
}

.col-item-selected .col-label {
  color: #4ade80;
  font-weight: 600;
}

.col-tip {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(15, 23, 42, 0.95);
  border: 1rpx solid rgba(34, 197, 94, 0.35);
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
}

.col-tip-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #4ade80;
}

.col-bar-area {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 4rpx;
}

.col-bar {
  width: 100%;
  max-width: 48rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: rgba(255, 255, 255, 0.06);
  min-height: 0;
  transition: height 0.25s ease;
}

.col-bar-active {
  background: linear-gradient(180deg, #34d399 0%, #22c55e 100%);
  box-shadow: 0 0 20rpx rgba(34, 197, 94, 0.25);
}

.col-bar-selected {
  box-shadow: 0 0 28rpx rgba(34, 197, 94, 0.45);
  filter: brightness(1.08);
}

.col-label {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #64748b;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
