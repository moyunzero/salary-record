.share-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 375px;
  height: 500px;
  opacity: 0;
  pointer-events: none;
}

.share-mask[hidden] {
  display: none !important;
}

.share-mask {
  position: fixed;
  inset: 0;
  z-index: 950;
  background: rgba(10, 16, 31, 0.72);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-panel {
  width: 100%;
  max-width: 750rpx;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.98) 0%, rgba(10, 16, 31, 0.99) 100%);
  border-top: 1rpx solid rgba(34, 197, 94, 0.25);
  box-shadow: 0 -24rpx 80rpx rgba(0, 0, 0, 0.45);
  animation: share-rise-in 0.32s ease-out;
}

@keyframes share-rise-in {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.share-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 8rpx auto 24rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.18);
}

.share-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.share-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 2rpx;
}

.share-subtitle {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
}

.share-card-preview {
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.14) 0%, rgba(255, 255, 255, 0.04) 100%);
  border: 1rpx solid rgba(34, 197, 94, 0.45);
  box-shadow: 0 12rpx 48rpx rgba(34, 197, 94, 0.12);
  margin-bottom: 8rpx;
}

.share-preview-brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.share-brand-mark {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.share-brand-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(34, 197, 94, 0.45);
}

.share-brand-hand {
  position: absolute;
  top: 8rpx;
  left: 14rpx;
  width: 20rpx;
  height: 20rpx;
  background: #22c55e;
  border-radius: 2rpx;
  transform: rotate(35deg);
  transform-origin: bottom center;
}

.share-brand-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  margin: -5rpx 0 0 -5rpx;
  border-radius: 50%;
  background: #22c55e;
}

.share-brand-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #94a3b8;
  letter-spacing: 2rpx;
}

.share-preview-label {
  display: block;
  font-size: 22rpx;
  color: #86efac;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.share-preview-hero {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 10rpx;
}

.share-preview-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #bbf7d0;
}

.share-preview-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #f8fafc;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.share-preview-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.share-preview-dot {
  color: #475569;
}

.share-disclaimer {
  display: block;
  font-size: 22rpx;
  color: #475569;
  margin-top: 8rpx;
}

.share-loading {
  text-align: center;
  color: #64748b;
  padding: 64rpx 0;
  font-size: 26rpx;
}

.share-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 28rpx;
}

.share-btn {
  width: 100% !important;
  margin: 0 !important;
  padding: 24rpx 0 !important;
  line-height: 1.4 !important;
  border-radius: 48rpx !important;
  font-weight: 600;
  font-size: 30rpx;
}

.share-btn-primary {
  background: linear-gradient(180deg, #34d399 0%, #22c55e 100%) !important;
  color: #052e16 !important;
  box-shadow: 0 12rpx 40rpx rgba(34, 197, 94, 0.35);
}

.share-btn-ghost {
  background: rgba(255, 255, 255, 0.06) !important;
  color: #94a3b8 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.share-btn-hover {
  transform: scale(0.98);
}

.share-dev-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #475569;
  line-height: 1.5;
  margin-top: 4rpx;
}

.share-dismiss {
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding: 28rpx 16rpx 8rpx;
}
