.home-card {
  padding: 16rpx 28rpx 32rpx;
}

.home-hero {
  text-align: center;
  margin-bottom: 24rpx;
  padding-top: 8rpx;
}

.home-hero-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.home-hero-amount {
  justify-content: center;
}

.home-hero-currency {
  font-size: 40rpx;
}

.home-amount-lg {
  font-size: 80rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.home-amount-md {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.home-amount-sm {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.ring-outer-home {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  background: transparent !important;
}

.ring-svg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.ring-inner-home {
  position: relative;
  z-index: 1;
  width: 228rpx;
  height: 228rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.ring-kicker {
  font-size: 22rpx;
  color: #64748b;
  letter-spacing: 0.12em;
  line-height: 1.2;
}

.ring-kicker-overtime {
  color: #fb923c;
}

.ring-metric {
  margin-top: 6rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #4ade80;
  line-height: 1.1;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ring-metric-overtime {
  color: #f97316;
}

.ring-metric-idle {
  color: #475569;
  font-size: 40rpx;
}

.ring-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(249, 115, 22, 0.1);
  border: 1rpx solid rgba(249, 115, 22, 0.22);
}

.ring-footnote-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #f97316;
  box-shadow: 0 0 12rpx rgba(249, 115, 22, 0.6);
}

.ring-footnote text {
  font-size: 22rpx;
  color: #fdba74;
  line-height: 1;
}

.home-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.home-stat {
  text-align: center;
  flex: 1;
}

.home-stat-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.home-stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.home-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

.home-meta {
  justify-content: center;
  margin-top: 8rpx;
}

.home-pet-wrap {
  display: flex;
  justify-content: center;
  margin: 24rpx 0 16rpx;
  pointer-events: auto;
}
