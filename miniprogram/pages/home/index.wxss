.home-card {
  padding: 16rpx 28rpx 32rpx;
}

.home-hero {
  text-align: center;
  margin-bottom: 24rpx;
  padding-top: 8rpx;
}

.home-hero-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.home-hero-amount {
  justify-content: center;
}

.home-hero-currency {
  font-size: 40rpx;
}

.home-amount-lg {
  font-size: 80rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.home-amount-md {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.home-amount-sm {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
  transition: font-size 0.2s ease;
}

.ring-outer-home {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  background: transparent !important;
}

.ring-svg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.ring-inner-home {
  position: relative;
  z-index: 1;
  width: 228rpx;
  height: 228rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.ring-kicker {
  font-size: 22rpx;
  color: #64748b;
  letter-spacing: 0.12em;
  line-height: 1.2;
}

.ring-kicker-overtime {
  color: #fb923c;
}

.ring-metric {
  margin-top: 6rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #4ade80;
  line-height: 1.1;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ring-metric-overtime {
  color: #f97316;
}

.ring-metric-idle {
  color: #475569;
  font-size: 40rpx;
}

.ring-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(249, 115, 22, 0.1);
  border: 1rpx solid rgba(249, 115, 22, 0.22);
}

.ring-footnote-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #f97316;
  box-shadow: 0 0 12rpx rgba(249, 115, 22, 0.6);
}

.ring-footnote text {
  font-size: 22rpx;
  color: #fdba74;
  line-height: 1;
}

/* 休息态（午休/晚休）：青色，传达「暂停而非异常」 */
.ring-kicker-rest {
  color: #5eead4;
}

.ring-metric-rest {
  color: #2dd4bf;
  font-size: 44rpx;
}

.ring-footnote-rest {
  background: rgba(45, 212, 191, 0.1);
  border-color: rgba(45, 212, 191, 0.22);
}

.ring-footnote-rest .ring-footnote-dot {
  background: #2dd4bf;
  box-shadow: 0 0 12rpx rgba(45, 212, 191, 0.6);
}

.ring-footnote-rest text {
  color: #5eead4;
}

.home-hero-paused {
  opacity: 0.62;
}

.home-rest-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(45, 212, 191, 0.12);
  border: 1rpx solid rgba(45, 212, 191, 0.26);
  font-size: 22rpx;
  color: #5eead4;
}

.home-rest-chip-icon {
  font-size: 22rpx;
  line-height: 1;
}

/* 节假日/休息日上班：倍数加班费胶囊（暖金） */
.home-rest-chip-premium {
  background: rgba(251, 191, 36, 0.14);
  border: 1rpx solid rgba(251, 191, 36, 0.32);
  color: #fbbf24;
}

/* 休息日主视觉（替代收入大数字） */
.home-rest-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin: 18rpx 0 4rpx;
}

.home-rest-hero-emoji {
  font-size: 88rpx;
  line-height: 1;
}

.home-rest-hero-text {
  font-size: 28rpx;
  color: #cbd5e1;
}

/* 加班计薪环（暖金） */
.ring-kicker-premium {
  color: #fcd34d;
}

.ring-metric-premium {
  color: #fbbf24;
}

.ring-footnote-premium {
  background: rgba(251, 191, 36, 0.1);
  border-color: rgba(251, 191, 36, 0.24);
}

.ring-footnote-premium .ring-footnote-dot {
  background: #fbbf24;
  box-shadow: 0 0 12rpx rgba(251, 191, 36, 0.6);
}

.ring-footnote-premium text {
  color: #fcd34d;
}

/* 休息日「今天要上班」按钮（暖金描边，区别于工作日绿色主按钮） */
.home-cta-rest {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
}

.home-rest-note {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  font-size: 24rpx;
  color: #94a3b8;
}

.home-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.home-stat {
  text-align: center;
  flex: 1;
}

.home-stat-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.home-stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.home-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

.home-meta {
  justify-content: center;
  margin-top: 8rpx;
}

/* 上界锚点：紧跟收工按钮，margin-top = 10rpx 间距 */
.home-pet-bound-top {
  width: 100%;
  height: 0;
  margin-top: 10rpx;
  pointer-events: none;
}

/* 猫猫活动区：上界 JS 测量；下界贴 Tab 栏顶，留 10rpx 间距 */
.home-pet-dock {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  z-index: 20;
  pointer-events: none;
}

.home-pet-dock cat-pet {
  display: block;
  width: 100%;
  height: 100%;
  pointer-events: auto;
}
