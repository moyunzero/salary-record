.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.schedule-label {
  font-size: 28rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.schedule-pickers {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.schedule-picker {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  padding: 12rpx 0;
}

.schedule-dash {
  font-size: 28rpx;
  color: #64748b;
}

.schedule-computed {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.schedule-computed-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #22c55e;
}

.schedule-night-row {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}
