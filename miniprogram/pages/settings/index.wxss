.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.schedule-label {
  font-size: 28rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.schedule-pickers {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.schedule-picker {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  padding: 12rpx 0;
}

.schedule-dash {
  font-size: 28rpx;
  color: #64748b;
}

.schedule-computed {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.schedule-computed-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #22c55e;
}

.schedule-night-row {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.weekday-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.weekday-chips {
  display: flex;
  gap: 10rpx;
}

.weekday-chip {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #94a3b8;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.weekday-chip-active {
  color: #052e16;
  font-weight: 700;
  background: #22c55e;
  border-color: #22c55e;
}

/* 每周工作日：标签独占一行 + 全宽 7 格周条，避免横向溢出 */
.weekday-block {
  margin-bottom: 18rpx;
}

.weekday-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.weekday-auto-tag {
  font-size: 22rpx;
  color: #64748b;
}

.week-strip {
  display: flex;
  gap: 10rpx;
}

.week-cell {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* 工作日（绿色实心） */
.week-cell-work {
  color: #052e16;
  font-weight: 700;
  background: #22c55e;
  border-color: #22c55e;
}

/* 休息日（暗淡） */
.week-cell-rest {
  color: #475569;
}

/* 大小周交替（周六）：暖金虚线 */
.week-cell-alt {
  color: #fbbf24;
  font-weight: 700;
  background: rgba(251, 191, 36, 0.12);
  border: 1rpx dashed rgba(251, 191, 36, 0.5);
}

.weekday-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

/* 大小周「本周大/小周」选择 */
.bigsmall-toggle {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.bigsmall-chip {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.bigsmall-chip-active {
  color: #052e16;
  font-weight: 700;
  background: #22c55e;
  border-color: #22c55e;
}
