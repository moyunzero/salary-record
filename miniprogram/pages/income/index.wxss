.income-chart-card {
  padding: 24rpx 20rpx 32rpx;
  margin-bottom: 24rpx;
}

.income-segment {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.income-segment-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  transition: color 0.2s ease, background 0.2s ease;
}

.income-segment-active {
  color: #4ade80;
  font-weight: 600;
  background: rgba(34, 197, 94, 0.15);
  border-color: rgba(34, 197, 94, 0.45);
}

.income-period-summary {
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.income-summary-label {
  font-size: 22rpx;
  color: #64748b;
}

.income-summary-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
}

.income-summary-sep {
  font-size: 22rpx;
  color: #475569;
  margin: 0 4rpx;
}

.income-empty {
  padding: 48rpx 24rpx;
}

.income-calendar-card {
  padding: 24rpx 20rpx 32rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.calendar-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #94a3b8;
}

.calendar-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-tag {
  font-size: 18rpx;
  line-height: 1;
  padding: 2rpx 5rpx;
  border-radius: 6rpx;
}

.legend-tag-rest {
  color: #f87171;
  background: rgba(248, 113, 113, 0.16);
}

.legend-tag-work {
  color: #94a3b8;
  background: rgba(148, 163, 184, 0.16);
}

.legend-dot-work {
  background: #22c55e;
}

.legend-dot-premium {
  background: #fbbf24;
}

.legend-dot-comp {
  background: #60a5fa;
}
