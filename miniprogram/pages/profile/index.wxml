<view class="page-shell page-shell-tab page-shell-tab-tight">
  <view class="ambient ambient-top"></view>
  <view class="ambient ambient-side"></view>
  <view class="grain"></view>
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <view class="page-body">
    <view class="preview-card preview-card-lit">
      <view class="preview-label">卷前价</view>
      <view class="preview-hero">
        <text class="preview-currency">¥</text>
        <text class="preview-value tabular">{{previewHourly}}</text>
        <text class="preview-unit">/时</text>
      </view>
      <view class="preview-meta">
        <text>到手月薪 ¥{{previewNetMonthly}}</text>
        <text class="preview-dot">·</text>
        <text>{{previewMonthlyHours}} 刑期/月</text>
      </view>
    </view>

    <view class="card">
      <view class="section-head">
        <view class="section-badge">数</view>
        <view>
          <view class="section-label">社畜档案</view>
          <view class="title">血汗与曲线</view>
        </view>
      </view>

      <view class="profile-link-row" bindtap="onGoRecord">
        <view class="profile-link-main">
          <text class="profile-link-title">血汗记录</text>
          <text class="profile-link-hint">补录或修改历史血汗</text>
        </view>
        <text class="profile-link-chevron">›</text>
      </view>

      <view class="profile-link-row" bindtap="onGoIncome">
        <view class="profile-link-main">
          <text class="profile-link-title">血汗曲线</text>
          <text class="profile-link-hint">周/月统计与日历</text>
        </view>
        <text class="profile-link-chevron">›</text>
      </view>

      <view class="profile-link-row" bindtap="onGoSettings">
        <view class="profile-link-main">
          <text class="profile-link-title">社畜设置</text>
          <text class="profile-link-hint">{{settingsHint}}</text>
        </view>
        <text class="profile-link-chevron">›</text>
      </view>
    </view>
  </view>
</view>
