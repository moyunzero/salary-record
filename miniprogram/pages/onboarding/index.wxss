.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 16rpx;
  overflow-x: hidden;
}

.header {
  padding: 8rpx 32rpx 20rpx;
}

.content {
  padding: 8rpx 32rpx 0;
}

.header-brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.brand-mark {
  width: 72rpx;
  height: 72rpx;
}

.header-copy {
  flex: 1;
  min-width: 0;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.header-slogan {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #4ade80;
  letter-spacing: 1rpx;
}

.preview-placeholder {
  font-size: 28rpx;
  color: #64748b;
  padding: 12rpx 0 8rpx;
}

.preview-visible {
  border-color: rgba(34, 197, 94, 0.45);
  box-shadow: 0 12rpx 48rpx rgba(34, 197, 94, 0.12);
}

.card-salary {
  border-color: rgba(34, 197, 94, 0.15);
}

.footer {
  margin-top: 32rpx;
  padding: 8rpx 32rpx 32rpx;
}

.status-bar,
.header,
.content,
.footer {
  position: relative;
  z-index: 1;
}
