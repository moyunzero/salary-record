.record-card {
  padding: 8rpx 28rpx;
  margin-bottom: 24rpx;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.record-row:last-child {
  border-bottom: none;
}

.record-label {
  font-size: 28rpx;
  color: #94a3b8;
}

.record-picker {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  padding: 16rpx 0;
}

.record-preview-card {
  padding: 28rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.record-preview-hero {
  justify-content: center;
  margin: 12rpx 0 24rpx;
}

.record-preview-stats {
  margin-top: 0;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.record-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(249, 115, 22, 0.1);
  border: 1rpx solid rgba(249, 115, 22, 0.22);
}

.ring-footnote-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #f97316;
  box-shadow: 0 0 12rpx rgba(249, 115, 22, 0.6);
}

.record-footnote text {
  font-size: 22rpx;
  color: #fdba74;
}

.record-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ef4444;
}

.record-delete-btn {
  margin-top: 16rpx;
}

/* 日类型徽标 */
.record-day-badge {
  align-self: center;
  margin-bottom: 14rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.record-day-badge-holiday {
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.14);
  border: 1rpx solid rgba(251, 191, 36, 0.32);
}

.record-day-badge-rest {
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.1);
  border: 1rpx solid rgba(251, 191, 36, 0.24);
}

.record-day-badge-makeup {
  color: #94a3b8;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.record-preview-premium {
  color: #fbbf24;
}

.record-preview-note {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
}
