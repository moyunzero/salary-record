/* 薪时宝 v1 设计系统 — 全站共享 */

page {
  background: #0a101f;
  color: #f8fafc;
  min-height: 100vh;
  overflow-x: hidden;
}

.tabular {
  font-variant-numeric: tabular-nums;
  font-family: 'SF Mono', 'Menlo', 'DIN Alternate', monospace;
}

/* ── 页面壳层 ── */
.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.page-shell-tab {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.page-shell-tab-tight {
  padding-bottom: calc(108rpx + env(safe-area-inset-bottom));
}

.page-shell-sub {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.sub-nav-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0 20rpx;
  margin-bottom: 8rpx;
}

.sub-nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  line-height: 1;
  color: #94a3b8;
}

.sub-nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #f8fafc;
}

.profile-link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.profile-link-row:last-child {
  border-bottom: none;
}

.profile-link-main {
  flex: 1;
  min-width: 0;
}

.profile-link-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.profile-link-hint {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.profile-link-chevron {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 36rpx;
  color: #64748b;
}

.status-bar {
  position: relative;
  z-index: 2;
  width: 100%;
  flex-shrink: 0;
}

.page-body {
  position: relative;
  z-index: 1;
  padding-top: 16rpx;
}

.ambient {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.ambient-top {
  top: -120rpx;
  right: -80rpx;
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.2) 0%, rgba(34, 197, 94, 0) 68%);
}

.ambient-side {
  bottom: 200rpx;
  left: -160rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.07) 0%, rgba(34, 197, 94, 0) 70%);
}

.grain {
  position: absolute;
  inset: 0;
  opacity: 0.035;
  background-image: radial-gradient(rgba(255, 255, 255, 0.9) 0.6px, transparent 0.6px);
  background-size: 6px 6px;
  pointer-events: none;
  z-index: 0;
}

/* ── 品牌标记 ── */
.brand-mark {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.brand-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(34, 197, 94, 0.45);
  box-shadow: 0 0 24rpx rgba(34, 197, 94, 0.25);
}

.brand-hand {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 3rpx;
  height: 20rpx;
  margin-left: -2rpx;
  margin-top: -18rpx;
  background: #22c55e;
  border-radius: 2rpx;
  transform-origin: bottom center;
  transform: rotate(35deg);
}

.brand-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  margin: -5rpx 0 0 -5rpx;
  border-radius: 50%;
  background: #22c55e;
}

/* ── 页面头 ── */
.page-header {
  margin-bottom: 28rpx;
}

.page-header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

/* ── 预览卡 / 数据卡 ── */
.preview-card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.14) 0%, rgba(255, 255, 255, 0.04) 100%);
  border: 1rpx solid rgba(34, 197, 94, 0.28);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.28);
  margin-bottom: 24rpx;
}

.preview-card-lit {
  border-color: rgba(34, 197, 94, 0.45);
  box-shadow: 0 12rpx 48rpx rgba(34, 197, 94, 0.12);
}

.preview-label {
  font-size: 22rpx;
  color: #86efac;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.preview-hero {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 10rpx;
}

.preview-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #bbf7d0;
}

.preview-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #f8fafc;
  line-height: 1;
  letter-spacing: -1rpx;
}

.preview-value-lg {
  font-size: 72rpx;
}

.preview-unit {
  font-size: 28rpx;
  color: #94a3b8;
  margin-left: 4rpx;
}

.preview-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.preview-dot {
  color: #475569;
}

/* ── 卡片 ── */
.glass-card,
.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.22);
}

.card-accent {
  border-color: rgba(34, 197, 94, 0.15);
}

.section-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: rgba(34, 197, 94, 0.15);
  border: 1rpx solid rgba(34, 197, 94, 0.35);
  color: #4ade80;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 4rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  line-height: 1.3;
}

.hint {
  color: #64748b;
  font-size: 22rpx;
  margin: -8rpx 0 20rpx;
  line-height: 1.5;
}

/* ── 输入 ── */
.input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx;
  background: rgba(0, 0, 0, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.input-prefix {
  font-size: 40rpx;
  font-weight: 600;
  color: #4ade80;
  flex-shrink: 0;
}

.input-hero {
  flex: 1;
  height: 96rpx;
  color: #f8fafc;
  font-size: 44rpx;
  font-weight: 600;
}

.input-placeholder {
  color: #475569;
  font-size: 36rpx;
  font-weight: 500;
}

/* ── 预设选项 ── */
.preset-list {
  margin-bottom: 8rpx;
}

.preset-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
}

.preset-active {
  border-color: rgba(34, 197, 94, 0.55);
  background: rgba(34, 197, 94, 0.1);
  box-shadow: 0 0 0 1rpx rgba(34, 197, 94, 0.12);
}

.preset-radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(148, 163, 184, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.preset-active .preset-radio {
  border-color: #22c55e;
}

.preset-radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
}

.preset-content {
  flex: 1;
  min-width: 0;
}

.preset-name {
  display: block;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.preset-note {
  display: block;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.45;
}

/* ── 微调折叠 ── */
.fine-tune-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.fine-tune-chevron {
  font-size: 32rpx;
  line-height: 1;
  transform: rotate(90deg);
  transition: transform 0.25s ease;
  color: #475569;
}

.fine-tune-chevron.open {
  transform: rotate(-90deg);
  color: #22c55e;
}

.fine-tune-body {
  padding-top: 8rpx;
  animation: rise-in 0.3s ease;
}

.slider-row {
  width: 100%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.slider-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
  color: #e2e8f0;
  font-size: 26rpx;
}

.slider-label .tabular {
  color: #4ade80;
  font-weight: 600;
}

/* ── 按钮 ── */
.btn-primary {
  background: linear-gradient(180deg, #34d399 0%, #22c55e 100%) !important;
  color: #052e16 !important;
  border-radius: 48rpx;
  font-weight: 700;
  font-size: 32rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 12rpx 40rpx rgba(34, 197, 94, 0.35);
}

.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(34, 197, 94, 0.28) !important;
}

.btn-disabled {
  opacity: 0.45;
  box-shadow: none !important;
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.06) !important;
  color: #94a3b8 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  font-weight: 600;
  font-size: 30rpx;
  box-shadow: none !important;
}

.btn-block {
  width: 100%;
  margin-top: 32rpx;
}

/* ── 空状态 ── */
.empty-state {
  text-align: center;
  padding: 48rpx 24rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(34, 197, 94, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(34, 197, 94, 0.15);
}

.empty-icon-inner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 3rpx solid #22c55e;
  opacity: 0.7;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.phase-tag {
  display: inline-block;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #4ade80;
  background: rgba(34, 197, 94, 0.12);
  border: 1rpx solid rgba(34, 197, 94, 0.25);
}

.phase-tag-wrap {
  text-align: center;
  margin-top: 8rpx;
}

/* ── 首页环形进度（占位） ── */
.ring-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 32rpx;
}

.ring-outer {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: conic-gradient(rgba(255, 255, 255, 0.08) 0deg 360deg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(34, 197, 94, 0.2);
}

.ring-inner {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: #0a101f;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.ring-pct {
  font-size: 28rpx;
  color: #4ade80;
  margin-top: 8rpx;
}

/* ── 收入趋势占位柱 ── */
.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 16rpx;
  height: 200rpx;
  padding: 24rpx 0;
}

.chart-bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: linear-gradient(180deg, rgba(34, 197, 94, 0.5) 0%, rgba(34, 197, 94, 0.15) 100%);
}

@keyframes earned-breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.025);
  }
}

.earned-breathe {
  display: inline-block;
  animation: earned-breathe 2s ease-in-out infinite;
  will-change: transform;
}

@keyframes rise-in {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

button {
  background: initial;
}

button::after {
  border: none;
}

button:focus {
  outline: 0;
}

/* ── Money rain ── */
.money-rain-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  pointer-events: none;
  overflow: hidden;
}

.money-rain-particle {
  position: absolute;
  top: -40rpx;
  will-change: transform;
  animation: money-fall 2.8s ease-in forwards;
}

.money-rain-coin {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fde047, #eab308);
}

.money-rain-yen {
  font-size: 28rpx;
  font-weight: 700;
  color: #22c55e;
}

@keyframes money-fall {
  to {
    transform: translateY(110vh) rotate(360deg);
    opacity: 0;
  }
}

/* ── Share sheet ── */
.share-mask {
  position: fixed;
  inset: 0;
  z-index: 950;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
}

.share-panel {
  width: 100%;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(15, 23, 42, 0.98);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  animation: rise-in 0.28s ease-out;
}

.share-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
}

.share-subtitle {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.share-preview-img {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.share-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.share-dismiss {
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  padding: 16rpx;
  margin-top: 8rpx;
}

.sync-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  color: #e2e8f0;
  font-size: 28rpx;
}

.sync-logout {
  margin-top: 12rpx;
  padding: 16rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}
